{
  "name": "planpong",
  "version": "0.5.7",
  "description": "Multi-model adversarial plan review — orchestrates AI agents to critique and refine implementation plans",
  "type": "module",
  "bin": {
    "planpong": "dist/bin/planpong.js",
    "planpong-mcp": "dist/bin/planpong-mcp.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsx bin/planpong.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "plan-review",
    "adversarial",
    "ai-agents",
    "claude",
    "codex",
    "gemini"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewhml/planpong.git"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ora": "^8.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "ajv": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
